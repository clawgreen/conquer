# Conquer Server Environment Variables
# Copy to .env and fill in values

# Required for Postgres persistence (Railway provides this automatically)
DATABASE_URL=postgres://user:pass@host:5432/conquer

# JWT secret — generate a random 32+ character string for production
JWT_SECRET=change-me-in-production

# Server port (Railway sets PORT automatically)
PORT=3000

# CORS origins (comma-separated, update with your Railway domain)
CORS_ORIGIN=http://localhost:5173,https://your-app.up.railway.app

# Optional: log level
RUST_LOG=info,conquer_server=debug

# Optional: rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECS=60

# Optional: JWT expiry in hours
JWT_EXPIRY_HOURS=24
