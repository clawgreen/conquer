# Conquer — Production Environment Variables
# Copy to .env and fill in values

# Required — your domain name
DOMAIN=conquer.yourdomain.com

# Required — PostgreSQL password (generate: openssl rand -hex 24)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Required — JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-strong-secret

# Optional — log level
# RUST_LOG=info,conquer_server=info

# Optional — rate limiting
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_SECS=60
